# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Server-side only. Never expose to browser.

# ─── Deepgram ─────────────────────────────────────────────────────────────────
# Get from: https://console.deepgram.com → API Keys
# Nova-3 model: ~$0.0043/minute (~$0.13 per 30-min call)
DEEPGRAM_API_KEY=your-deepgram-api-key

# ─── Anthropic ────────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com → API Keys
# Using claude-sonnet for balance of quality vs cost
ANTHROPIC_API_KEY=your-anthropic-api-key

# ─── Slack ────────────────────────────────────────────────────────────────────
# Create a Slack app, add an Incoming Webhook, paste the URL here
# Optional — if empty, Slack notifications are skipped
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# ─── Recall.ai ────────────────────────────────────────────────────────────────
# Sign up at: https://recall.ai (free credits to start)
# Get API key from: Recall dashboard → API Keys
RECALL_API_KEY=your-recall-api-key

# Webhook secret — set this in Recall dashboard → Webhooks → create endpoint
# URL: https://your-app.vercel.app/api/recall/webhook
# Copy the signing secret and paste here
RECALL_WEBHOOK_SECRET=your-recall-webhook-secret   # Optional but strongly recommended in prod

# ─── Google OAuth (for Calendar integration) ──────────────────────────────────
# Create a project at: https://console.cloud.google.com
# Enable "Google Calendar API"
# OAuth consent screen → add scope: .../auth/calendar.readonly
# Credentials → Create OAuth 2.0 Client ID (Web application)
# Add authorised redirect URI: https://your-app.vercel.app/api/recall/oauth/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

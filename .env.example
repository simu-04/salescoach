# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Server-side only. Never expose to browser.

# ─── Deepgram ─────────────────────────────────────────────────────────────────
# Get from: https://console.deepgram.com → API Keys
# Nova-3 model: ~$0.0043/minute (~$0.13 per 30-min call)
DEEPGRAM_API_KEY=your-deepgram-api-key

# ─── Anthropic ────────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com → API Keys
# Using claude-sonnet for balance of quality vs cost
ANTHROPIC_API_KEY=your-anthropic-api-key

# ─── Slack ────────────────────────────────────────────────────────────────────
# Create a Slack app, add an Incoming Webhook, paste the URL here
# Optional — if empty, Slack notifications are skipped
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
